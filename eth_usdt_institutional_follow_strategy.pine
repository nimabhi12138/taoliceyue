//@version=6
strategy("ETH/USDT机构资金跟随策略", 
         shorttitle="机构跟随", 
         overlay=true, 
         initial_capital=50, 
         default_qty_type=strategy.percent_of_equity, 
         default_qty_value=95,
         commission_type=strategy.commission.percent, 
         commission_value=0.025,
         slippage=1,
         pyramiding=1,
         close_entries_rule="FIFO",
         max_bars_back=500)

import TradingView/ta/7 as ta

// ==================== 机构跟随核心参数 ====================
var g1 = "=== 机构识别设置 ==="
whale_threshold = input.float(2.0, "鲸鱼单倍数", minval=1.5, maxval=5.0, step=0.1, group=g1)
institution_volume_period = input.int(20, "机构成交量周期", minval=10, maxval=50, group=g1)
smart_money_sensitivity = input.float(1.5, "聪明钱敏感度", minval=1.0, maxval=3.0, step=0.1, group=g1)
order_flow_period = input.int(14, "订单流分析周期", minval=7, maxval=30, group=g1)

// 趋势跟随参数
var g2 = "=== 趋势跟随 ==="
trend_ema_short = input.int(12, "短期趋势EMA", minval=8, maxval=21, group=g2)
trend_ema_long = input.int(26, "长期趋势EMA", minval=21, maxval=55, group=g2)
trend_strength_period = input.int(14, "趋势强度周期", minval=7, maxval=30, group=g2)
adx_threshold = input.int(25, "ADX趋势阈值", minval=20, maxval=40, group=g2)

// 动量确认参数
var g3 = "=== 动量确认 ==="
momentum_rsi_period = input.int(14, "动量RSI周期", minval=7, maxval=21, group=g3)
momentum_macd_fast = input.int(12, "MACD快线", minval=8, maxval=16, group=g3)
momentum_macd_slow = input.int(26, "MACD慢线", minval=20, maxval=34, group=g3)
momentum_macd_signal = input.int(9, "MACD信号线", minval=6, maxval=12, group=g3)
stochastic_k = input.int(14, "随机指标K", minval=10, maxval=20, group=g3)
stochastic_d = input.int(3, "随机指标D", minval=2, maxval=5, group=g3)

// 波动率和风险参数
var g4 = "=== 波动率风险 ==="
atr_period = input.int(14, "ATR周期", minval=7, maxval=21, group=g4)
bollinger_period = input.int(20, "布林带周期", minval=15, maxval=30, group=g4)
bollinger_std = input.float(2.0, "布林带标准差", minval=1.5, maxval=2.5, step=0.1, group=g4)
volatility_filter = input.bool(true, "启用波动率过滤", group=g4)

// 高级风险管理
var g5 = "=== 高级风险管理 ==="
risk_per_trade = input.float(1.5, "单笔风险百分比", minval=0.5, maxval=3.0, step=0.1, group=g5)
max_correlation_trades = input.int(2, "最大相关交易数", minval=1, maxval=5, group=g5)
drawdown_limit = input.float(15.0, "最大回撤限制(%)", minval=5.0, maxval=25.0, step=1.0, group=g5)
profit_target_mult = input.float(2.5, "盈利目标倍数", minval=1.5, maxval=4.0, step=0.1, group=g5)

// 市场环境参数
var g6 = "=== 市场环境 ==="
market_regime_period = input.int(50, "市场状态周期", minval=30, maxval=100, group=g6)
volatility_regime_mult = input.float(1.2, "波动率状态倍数", minval=1.0, maxval=2.0, step=0.1, group=g6)
trend_regime_threshold = input.float(0.02, "趋势状态阈值", minval=0.01, maxval=0.05, step=0.001, group=g6)

// ==================== 核心指标计算 ====================

// 趋势指标
ema_short = ta.ema(close, trend_ema_short)
ema_long = ta.ema(close, trend_ema_long)
trend_direction = ema_short > ema_long ? 1 : ema_short < ema_long ? -1 : 0

// ADX趋势强度
[diplus, diminus, adx] = ta.dmi(adx_threshold, trend_strength_period)
strong_trend = adx > adx_threshold

// 动量指标
rsi = ta.rsi(close, momentum_rsi_period)
[macd_line, signal_line, histogram] = ta.macd(close, momentum_macd_fast, momentum_macd_slow, momentum_macd_signal)
stoch_k = ta.stoch(close, high, low, stochastic_k)
stoch_d = ta.sma(stoch_k, stochastic_d)

// 波动率指标
atr = ta.atr(atr_period)
[bb_upper, bb_middle, bb_lower] = ta.bb(close, bollinger_period, bollinger_std)
bb_width = (bb_upper - bb_lower) / bb_middle

// 成交量分析
volume_sma = ta.sma(volume, institution_volume_period)
volume_ema = ta.ema(volume, institution_volume_period)
relative_volume = volume / volume_sma

// ==================== 机构行为识别 ====================

// 1. 鲸鱼单识别
whale_volume = volume > volume_sma * whale_threshold
whale_buying = whale_volume and close > open and (close - open) > (high - low) * 0.5
whale_selling = whale_volume and close < open and (open - close) > (high - low) * 0.5

// 2. 聪明钱指标 (Money Flow Index的改进版)
typical_price = hlc3
money_flow = typical_price * volume
positive_flow = close > close[1] ? money_flow : 0
negative_flow = close < close[1] ? money_flow : 0
money_flow_ratio = ta.sum(positive_flow, smart_money_sensitivity * 10) / ta.sum(negative_flow, smart_money_sensitivity * 10)
smart_money_index = 100 - (100 / (1 + money_flow_ratio))

smart_money_bullish = smart_money_index > 50 and smart_money_index > smart_money_index[1]
smart_money_bearish = smart_money_index < 50 and smart_money_index < smart_money_index[1]

// 3. 订单流不平衡检测
buy_volume = close > open ? volume : 0
sell_volume = close < open ? volume : 0
buy_pressure = ta.sum(buy_volume, order_flow_period)
sell_pressure = ta.sum(sell_volume, order_flow_period)
order_flow_ratio = buy_pressure / (buy_pressure + sell_pressure)

order_flow_bullish = order_flow_ratio > 0.6
order_flow_bearish = order_flow_ratio < 0.4

// 4. 价格-成交量分歧
price_change = (close - close[order_flow_period]) / close[order_flow_period]
volume_change = (volume_sma - volume_sma[order_flow_period]) / volume_sma[order_flow_period]
pv_divergence_bull = price_change < 0 and volume_change > 0.1  // 价格下跌但成交量增加
pv_divergence_bear = price_change > 0 and volume_change > 0.1  // 价格上涨但成交量增加

// 5. 大单流入流出
cumulative_volume = ta.cum(volume)
cumulative_dollar_volume = ta.cum(volume * close)
vwap_institutional = cumulative_dollar_volume / cumulative_volume

institution_accumulation = close > vwap_institutional and volume > volume_sma * 1.2
institution_distribution = close < vwap_institutional and volume > volume_sma * 1.2

// ==================== 市场状态识别 ====================

// 市场波动率状态
volatility_avg = ta.sma(atr / close, market_regime_period)
current_volatility = atr / close
high_volatility_regime = current_volatility > volatility_avg * volatility_regime_mult
low_volatility_regime = current_volatility < volatility_avg / volatility_regime_mult

// 市场趋势状态
price_change_avg = ta.sma(math.abs((close - close[1]) / close[1]), market_regime_period)
trending_market = price_change_avg > trend_regime_threshold
ranging_market = price_change_avg < trend_regime_threshold * 0.5

// 市场情绪状态
fear_greed_proxy = (rsi - 50) / 50  // 简化的恐惧贪婪指数
extreme_fear = fear_greed_proxy < -0.4
extreme_greed = fear_greed_proxy > 0.4

// ==================== 信号生成系统 ====================

// 多头信号组件
long_trend = trend_direction == 1 and strong_trend
long_momentum = rsi > 45 and rsi < 75 and macd_line > signal_line and stoch_k > stoch_d
long_volume = relative_volume > 1.2 and (whale_buying or smart_money_bullish or order_flow_bullish)
long_institution = institution_accumulation or pv_divergence_bull
long_structure = close > bb_middle and close > ema_short
long_market_state = not extreme_greed and (trending_market or not high_volatility_regime)

// 空头信号组件  
short_trend = trend_direction == -1 and strong_trend
short_momentum = rsi > 25 and rsi < 55 and macd_line < signal_line and stoch_k < stoch_d
short_volume = relative_volume > 1.2 and (whale_selling or smart_money_bearish or order_flow_bearish)
short_institution = institution_distribution or pv_divergence_bear
short_structure = close < bb_middle and close < ema_short
short_market_state = not extreme_fear and (trending_market or not high_volatility_regime)

// 信号强度评分
long_strength = 0
long_strength += long_trend ? 3 : 0
long_strength += long_momentum ? 2 : 0
long_strength += long_volume ? 3 : 0
long_strength += long_institution ? 2 : 0
long_strength += long_structure ? 1 : 0
long_strength += long_market_state ? 1 : 0

short_strength = 0
short_strength += short_trend ? 3 : 0
short_strength += short_momentum ? 2 : 0
short_strength += short_volume ? 3 : 0
short_strength += short_institution ? 2 : 0
short_strength += short_structure ? 1 : 0
short_strength += short_market_state ? 1 : 0

// 最终信号确认
min_signal_strength = 7  // 最低信号强度要求
long_signal = long_strength >= min_signal_strength and not volatility_filter or not high_volatility_regime
short_signal = short_strength >= min_signal_strength and not volatility_filter or not high_volatility_regime

// ==================== 高级风险管理 ====================

// 动态仓位计算
account_value = strategy.equity
risk_amount = account_value * risk_per_trade / 100
atr_risk = atr * 1.0  // 1倍ATR作为基础风险
position_size = risk_amount / atr_risk

// 最大回撤保护
current_drawdown = (strategy.max_equity - strategy.equity) / strategy.max_equity * 100
drawdown_protection = current_drawdown < drawdown_limit

// 相关性风险控制
var int active_long_trades = 0
var int active_short_trades = 0

if strategy.position_size > 0
    active_long_trades := 1
else if strategy.position_size < 0
    active_short_trades := 1
else
    active_long_trades := 0
    active_short_trades := 0

correlation_check = (active_long_trades + active_short_trades) < max_correlation_trades

// 动态止损止盈
long_stop_loss = close - atr * 1.5
long_take_profit = close + atr * profit_target_mult
short_stop_loss = close + atr * 1.5
short_take_profit = close - atr * profit_target_mult

// 追踪止损
var float long_trail_stop = na
var float short_trail_stop = na

if strategy.position_size > 0
    long_trail_stop := na(long_trail_stop) ? long_stop_loss : math.max(long_trail_stop, close - atr * 2.0)
else
    long_trail_stop := na

if strategy.position_size < 0
    short_trail_stop := na(short_trail_stop) ? short_stop_loss : math.min(short_trail_stop, close + atr * 2.0)
else
    short_trail_stop := na

// ==================== 交易执行逻辑 ====================

// 入场条件检查
can_enter_long = long_signal and drawdown_protection and correlation_check and strategy.position_size == 0
can_enter_short = short_signal and drawdown_protection and correlation_check and strategy.position_size == 0

// 执行多头交易
if can_enter_long
    strategy.entry("InstitutionalLong", strategy.long, qty=position_size, comment="机构跟随多头")
    strategy.exit("LongExit", "InstitutionalLong", limit=long_take_profit, stop=long_stop_loss, comment="多头出场")

// 执行空头交易
if can_enter_short
    strategy.entry("InstitutionalShort", strategy.short, qty=position_size, comment="机构跟随空头")
    strategy.exit("ShortExit", "InstitutionalShort", limit=short_take_profit, stop=short_stop_loss, comment="空头出场")

// 追踪止损更新
if not na(long_trail_stop) and strategy.position_size > 0
    strategy.exit("LongTrail", "InstitutionalLong", stop=long_trail_stop, comment="多头追踪止损")

if not na(short_trail_stop) and strategy.position_size < 0
    strategy.exit("ShortTrail", "InstitutionalShort", stop=short_trail_stop, comment="空头追踪止损")

// 紧急出场条件
emergency_exit_long = strategy.position_size > 0 and (extreme_greed or current_drawdown > drawdown_limit * 0.8)
emergency_exit_short = strategy.position_size < 0 and (extreme_fear or current_drawdown > drawdown_limit * 0.8)

if emergency_exit_long
    strategy.close("InstitutionalLong", comment="紧急平多")
if emergency_exit_short
    strategy.close("InstitutionalShort", comment="紧急平空")

// ==================== 图表可视化 ====================

// 绘制关键均线和指标
plot(ema_short, "短期EMA", color=color.blue, linewidth=1)
plot(ema_long, "长期EMA", color=color.red, linewidth=1)
plot(vwap_institutional, "机构VWAP", color=color.purple, linewidth=2)

// 绘制布林带
p1 = plot(bb_upper, "BB上轨", color=color.gray, linewidth=1)
p2 = plot(bb_lower, "BB下轨", color=color.gray, linewidth=1)
fill(p1, p2, color=color.new(color.gray, 95), title="布林带区间")

// 机构行为标记
plotshape(whale_buying, "鲸鱼买入", location.belowbar, color=color.green, style=shape.diamond, size=size.small)
plotshape(whale_selling, "鲸鱼卖出", location.abovebar, color=color.red, style=shape.diamond, size=size.small)

// 交易信号标记
plotshape(long_signal, "机构跟随多头", location.belowbar, color=color.lime, style=shape.triangleup, size=size.normal)
plotshape(short_signal, "机构跟随空头", location.abovebar, color=color.fuchsia, style=shape.triangledown, size=size.normal)

// 市场状态背景
bgcolor(high_volatility_regime ? color.new(color.orange, 90) : na, title="高波动环境")
bgcolor(trending_market ? color.new(color.blue, 95) : ranging_market ? color.new(color.yellow, 95) : na, title="市场状态")

// ==================== 综合监控面板 ====================

if barstate.islast
    var table monitor_table = table.new(position.top_right, 3, 12, bgcolor=color.white, border_width=1)
    
    // 表头
    table.cell(monitor_table, 0, 0, "机构跟随监控", text_color=color.white, bgcolor=color.navy)
    table.cell(monitor_table, 1, 0, "状态", text_color=color.white, bgcolor=color.navy)
    table.cell(monitor_table, 2, 0, "数值", text_color=color.white, bgcolor=color.navy)
    
    // 趋势状态
    table.cell(monitor_table, 0, 1, "趋势方向", text_color=color.black)
    trend_text = trend_direction == 1 ? "上涨" : trend_direction == -1 ? "下跌" : "震荡"
    trend_color = trend_direction == 1 ? color.green : trend_direction == -1 ? color.red : color.orange
    table.cell(monitor_table, 1, 1, trend_text, text_color=trend_color)
    table.cell(monitor_table, 2, 1, "ADX: " + str.tostring(math.round(adx)), text_color=color.black)
    
    // 机构资金
    table.cell(monitor_table, 0, 2, "机构资金", text_color=color.black)
    inst_text = institution_accumulation ? "积累" : institution_distribution ? "分发" : "中性"
    inst_color = institution_accumulation ? color.green : institution_distribution ? color.red : color.orange
    table.cell(monitor_table, 1, 2, inst_text, text_color=inst_color)
    table.cell(monitor_table, 2, 2, "SMI: " + str.tostring(math.round(smart_money_index)), text_color=color.black)
    
    // 订单流
    table.cell(monitor_table, 0, 3, "订单流", text_color=color.black)
    flow_text = order_flow_bullish ? "买盘优势" : order_flow_bearish ? "卖盘优势" : "平衡"
    flow_color = order_flow_bullish ? color.green : order_flow_bearish ? color.red : color.orange
    table.cell(monitor_table, 1, 3, flow_text, text_color=flow_color)
    table.cell(monitor_table, 2, 3, str.tostring(math.round(order_flow_ratio * 100)) + "%", text_color=color.black)
    
    // 成交量分析
    table.cell(monitor_table, 0, 4, "成交量", text_color=color.black)
    vol_text = whale_volume ? "鲸鱼单" : relative_volume > 1.5 ? "放大" : "正常"
    vol_color = whale_volume ? color.purple : relative_volume > 1.5 ? color.blue : color.gray
    table.cell(monitor_table, 1, 4, vol_text, text_color=vol_color)
    table.cell(monitor_table, 2, 4, str.tostring(math.round(relative_volume, 2)) + "x", text_color=color.black)
    
    // 动量指标
    table.cell(monitor_table, 0, 5, "动量", text_color=color.black)
    momentum_text = rsi > 60 ? "强势" : rsi < 40 ? "弱势" : "中性"
    momentum_color = rsi > 60 ? color.green : rsi < 40 ? color.red : color.orange
    table.cell(monitor_table, 1, 5, momentum_text, text_color=momentum_color)
    table.cell(monitor_table, 2, 5, "RSI: " + str.tostring(math.round(rsi)), text_color=color.black)
    
    // 波动率状态
    table.cell(monitor_table, 0, 6, "波动率", text_color=color.black)
    vol_regime_text = high_volatility_regime ? "高波动" : low_volatility_regime ? "低波动" : "正常"
    vol_regime_color = high_volatility_regime ? color.red : low_volatility_regime ? color.green : color.orange
    table.cell(monitor_table, 1, 6, vol_regime_text, text_color=vol_regime_color)
    table.cell(monitor_table, 2, 6, str.tostring(math.round(current_volatility * 100, 3)) + "%", text_color=color.black)
    
    // 市场状态
    table.cell(monitor_table, 0, 7, "市场状态", text_color=color.black)
    market_text = trending_market ? "趋势" : ranging_market ? "震荡" : "过渡"
    market_color = trending_market ? color.blue : ranging_market ? color.yellow : color.orange
    table.cell(monitor_table, 1, 7, market_text, text_color=market_color)
    table.cell(monitor_table, 2, 7, str.tostring(math.round(price_change_avg * 100, 3)) + "%", text_color=color.black)
    
    // 信号强度
    table.cell(monitor_table, 0, 8, "多头信号", text_color=color.black)
    table.cell(monitor_table, 1, 8, str.tostring(long_strength) + "/12", text_color=long_strength >= min_signal_strength ? color.green : color.red)
    table.cell(monitor_table, 2, 8, long_signal ? "激活" : "等待", text_color=long_signal ? color.green : color.orange)
    
    table.cell(monitor_table, 0, 9, "空头信号", text_color=color.black)
    table.cell(monitor_table, 1, 9, str.tostring(short_strength) + "/12", text_color=short_strength >= min_signal_strength ? color.red : color.gray)
    table.cell(monitor_table, 2, 9, short_signal ? "激活" : "等待", text_color=short_signal ? color.red : color.orange)
    
    // 风险管理
    table.cell(monitor_table, 0, 10, "风险控制", text_color=color.black)
    risk_text = drawdown_protection ? "正常" : "限制"
    risk_color = drawdown_protection ? color.green : color.red
    table.cell(monitor_table, 1, 10, risk_text, text_color=risk_color)
    table.cell(monitor_table, 2, 10, str.tostring(math.round(current_drawdown, 2)) + "%", text_color=color.black)
    
    // 当前持仓
    table.cell(monitor_table, 0, 11, "当前持仓", text_color=color.black)
    pos_text = strategy.position_size > 0 ? "多头" : strategy.position_size < 0 ? "空头" : "空仓"
    pos_color = strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray
    table.cell(monitor_table, 1, 11, pos_text, text_color=pos_color)
    table.cell(monitor_table, 2, 11, "$" + str.tostring(math.round(strategy.position_avg_price, 2)), text_color=color.black)

// ==================== 策略性能报告 ====================

if barstate.islast and strategy.closedtrades > 5
    total_trades = strategy.closedtrades
    win_rate = strategy.wintrades / total_trades * 100
    profit_factor = strategy.grossprofit / math.abs(strategy.grossloss)
    avg_win = strategy.grossprofit / strategy.wintrades
    avg_loss = math.abs(strategy.grossloss) / strategy.losstrades
    expectancy = (win_rate / 100 * avg_win) - ((100 - win_rate) / 100 * avg_loss)
    
    var table performance_table = table.new(position.bottom_right, 2, 8, bgcolor=color.white, border_width=1)
    
    table.cell(performance_table, 0, 0, "策略表现", text_color=color.white, bgcolor=color.navy)
    table.cell(performance_table, 1, 0, "数值", text_color=color.white, bgcolor=color.navy)
    
    table.cell(performance_table, 0, 1, "总交易数", text_color=color.black)
    table.cell(performance_table, 1, 1, str.tostring(total_trades), text_color=color.black)
    
    table.cell(performance_table, 0, 2, "胜率", text_color=color.black)
    table.cell(performance_table, 1, 2, str.tostring(math.round(win_rate, 1)) + "%", 
               text_color=win_rate >= 70 ? color.green : win_rate >= 60 ? color.orange : color.red)
    
    table.cell(performance_table, 0, 3, "盈利因子", text_color=color.black)
    table.cell(performance_table, 1, 3, str.tostring(math.round(profit_factor, 2)), 
               text_color=profit_factor >= 2.0 ? color.green : profit_factor >= 1.5 ? color.orange : color.red)
    
    table.cell(performance_table, 0, 4, "期望收益", text_color=color.black)
    table.cell(performance_table, 1, 4, "$" + str.tostring(math.round(expectancy, 2)), 
               text_color=expectancy > 0 ? color.green : color.red)
    
    table.cell(performance_table, 0, 5, "总盈亏", text_color=color.black)
    table.cell(performance_table, 1, 5, "$" + str.tostring(math.round(strategy.netprofit, 2)), 
               text_color=strategy.netprofit > 0 ? color.green : color.red)
    
    table.cell(performance_table, 0, 6, "最大回撤", text_color=color.black)
    table.cell(performance_table, 1, 6, str.tostring(math.round(strategy.max_drawdown, 2)) + "%", 
               text_color=strategy.max_drawdown < 10 ? color.green : strategy.max_drawdown < 20 ? color.orange : color.red)
    
    table.cell(performance_table, 0, 7, "夏普比率", text_color=color.black)
    sharpe_approx = strategy.netprofit / math.max(strategy.max_drawdown, 1)
    table.cell(performance_table, 1, 7, str.tostring(math.round(sharpe_approx, 2)), 
               text_color=sharpe_approx > 2 ? color.green : sharpe_approx > 1 ? color.orange : color.red)