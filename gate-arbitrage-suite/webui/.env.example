# Gate.io Arbitrage Suite Web UI Configuration

# Admin Credentials (CHANGE THESE!)
ADMIN_USER=admin
ADMIN_PASSWORD=your_secure_password_here

# Hummingbot Connection
HUMMINGBOT_HOST=localhost
HUMMINGBOT_PORT=8211

# Web UI Ports
WEB_PORT=8080
API_PORT=8000
FRONTEND_PORT=8501

# Database (optional, for metrics storage)
DATABASE_URL=sqlite:///./gate_arb.db

# Telegram Alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email Alerts (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# Security
JWT_SECRET_KEY=your_jwt_secret_key_here
CORS_ORIGINS=http://localhost:8501,http://localhost:8080

# Logging
LOG_LEVEL=INFO
LOG_FILE=/logs/webui.log

# Performance
MAX_WORKERS=4
REQUEST_TIMEOUT=30