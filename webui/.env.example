# Backend
BACKEND_PORT=8000
HUMMINGBOT_API_BASE=http://host.docker.internal:5000  # if HB REST API enabled; else leave blank
HUMMINGBOT_CLI_BIN=/usr/local/bin/hb                # optional path to HB CLI
HUMMINGBOT_LOG_PATH=/workspace/logs/hummingbot.log  # adjust to your HB logs

# Frontend
FRONTEND_PORT=8501
BACKEND_BASE_URL=http://localhost:8000

# Basic Auth (set both to enable)
WEBUI_USERNAME=admin
WEBUI_PASSWORD=changeme