//@version=6
strategy("ETH/USDT 高胜率机构跟随策略", overlay=true, 
         default_qty_type=strategy.percent_of_equity, 
         default_qty_value=100, 
         currency=currency.USD,
         commission_type=strategy.commission.percent,
         commission_value=0.025,  // Gate.io永续合约手续费0.025%
         slippage=2)  // 考虑滑点

// ==================== 策略参数设置 ====================
// 基础参数
fast_ema = input.int(8, title="快速EMA周期", minval=1, maxval=50)
slow_ema = input.int(21, title="慢速EMA周期", minval=1, maxval=100)
rsi_period = input.int(14, title="RSI周期", minval=1, maxval=50)
rsi_oversold = input.int(25, title="RSI超卖线", minval=10, maxval=40)
rsi_overbought = input.int(75, title="RSI超买线", minval=60, maxval=90)

// 成交量分析参数
volume_ma_period = input.int(20, title="成交量均线周期", minval=5, maxval=50)
volume_threshold = input.float(1.5, title="成交量放大倍数", minval=1.0, maxval=3.0)

// 波动率参数
atr_period = input.int(14, title="ATR周期", minval=5, maxval=30)
bb_period = input.int(20, title="布林带周期", minval=10, maxval=50)
bb_mult = input.float(2.0, title="布林带倍数", minval=1.0, maxval=3.0)

// 风险管理参数
risk_per_trade = input.float(2.0, title="每笔交易风险(%)", minval=0.5, maxval=5.0)
take_profit_ratio = input.float(2.5, title="止盈比例", minval=1.0, maxval=5.0)
stop_loss_ratio = input.float(1.0, title="止损比例", minval=0.5, maxval=2.0)

// 高级过滤参数
enable_macd_filter = input.bool(true, title="启用MACD过滤")
enable_stoch_filter = input.bool(true, title="启用随机指标过滤")
enable_vwap_filter = input.bool(true, title="启用VWAP过滤")
enable_time_filter = input.bool(true, title="启用时间过滤")

// 时间过滤设置
start_hour = input.int(8, title="开始交易时间(小时)", minval=0, maxval=23)
end_hour = input.int(22, title="结束交易时间(小时)", minval=0, maxval=23)

// ==================== 技术指标计算 ====================

// 移动平均线
ema_fast = ta.ema(close, fast_ema)
ema_slow = ta.ema(close, slow_ema)

// RSI指标
rsi = ta.rsi(close, rsi_period)

// MACD指标
[macd_line, signal_line, hist] = ta.macd(close, 12, 26, 9)

// 随机指标
k = ta.stoch(close, high, low, 14)
d = ta.sma(k, 3)

// 布林带
[bb_upper, bb_middle, bb_lower] = ta.bb(close, bb_period, bb_mult)

// ATR波动率
atr = ta.atr(atr_period)

// VWAP (成交量加权平均价格)
vwap = ta.vwap(hlc3)

// 成交量分析
volume_ma = ta.sma(volume, volume_ma_period)
volume_spike = volume > volume_ma * volume_threshold

// 价格动量
price_momentum = (close - close[5]) / close[5] * 100

// ==================== 多时间框架分析 ====================

// 5分钟时间框架的EMA (通过request.security获取)
ema_fast_5m = request.security(syminfo.tickerid, "5", ta.ema(close, fast_ema))
ema_slow_5m = request.security(syminfo.tickerid, "5", ta.ema(close, slow_ema))
rsi_5m = request.security(syminfo.tickerid, "5", ta.rsi(close, rsi_period))

// 趋势方向判断
trend_up_5m = ema_fast_5m > ema_slow_5m
trend_down_5m = ema_fast_5m < ema_slow_5m

// ==================== 机构跟随信号 ====================

// 大单检测 (基于成交量和价格变化)
big_order_up = volume_spike and close > open and (close - open) / open > 0.002
big_order_down = volume_spike and close < open and (open - close) / open > 0.002

// 资金流向分析
money_flow = ta.mfi(hlc3, 14)
money_flow_bullish = money_flow > 50 and money_flow > money_flow[1]
money_flow_bearish = money_flow < 50 and money_flow < money_flow[1]

// ==================== 交易信号生成 ====================

// 时间过滤
time_ok = not enable_time_filter or (hour >= start_hour and hour <= end_hour)

// 多头信号条件
long_ema_cross = ta.crossover(ema_fast, ema_slow)
long_rsi_ok = rsi > rsi_oversold and rsi < rsi_overbought
long_macd_ok = not enable_macd_filter or (macd_line > signal_line and hist > hist[1])
long_stoch_ok = not enable_stoch_filter or (k > 20 and k < 80)
long_vwap_ok = not enable_vwap_filter or close > vwap
long_bb_ok = close > bb_lower and close < bb_upper
long_trend_ok = trend_up_5m
long_volume_ok = volume_spike
long_momentum_ok = price_momentum > -1.0

// 空头信号条件
short_ema_cross = ta.crossunder(ema_fast, ema_slow)
short_rsi_ok = rsi > rsi_oversold and rsi < rsi_overbought
short_macd_ok = not enable_macd_filter or (macd_line < signal_line and hist < hist[1])
short_stoch_ok = not enable_stoch_filter or (k > 20 and k < 80)
short_vwap_ok = not enable_vwap_filter or close < vwap
short_bb_ok = close > bb_lower and close < bb_upper
short_trend_ok = trend_down_5m
short_volume_ok = volume_spike
short_momentum_ok = price_momentum < 1.0

// 综合信号
long_signal = time_ok and long_ema_cross and long_rsi_ok and long_macd_ok and 
              long_stoch_ok and long_vwap_ok and long_bb_ok and long_trend_ok and 
              long_volume_ok and long_momentum_ok and money_flow_bullish

short_signal = time_ok and short_ema_cross and short_rsi_ok and short_macd_ok and 
               short_stoch_ok and short_vwap_ok and short_bb_ok and short_trend_ok and 
               short_volume_ok and short_momentum_ok and money_flow_bearish

// 机构跟随增强信号
long_institutional = long_signal and (big_order_up or money_flow > 60)
short_institutional = short_signal and (big_order_down or money_flow < 40)

// ==================== 风险管理 ====================

// 动态止损止盈计算
long_stop_loss = close - atr * stop_loss_ratio
long_take_profit = close + atr * take_profit_ratio
short_stop_loss = close + atr * stop_loss_ratio
short_take_profit = close - atr * take_profit_ratio

// 仓位大小计算 (基于风险百分比)
account_balance = strategy.equity
risk_amount = account_balance * risk_per_trade / 100
position_size = math.min(risk_amount / (atr * stop_loss_ratio), account_balance * 0.95 / close)

// ==================== 交易执行 ====================

// 多头交易
if long_institutional and strategy.position_size == 0 and position_size > 0
    strategy.entry("Long", strategy.long, qty=position_size)
    strategy.exit("Long Exit", "Long", 
                  limit=long_take_profit, 
                  stop=long_stop_loss)

// 空头交易
if short_institutional and strategy.position_size == 0 and position_size > 0
    strategy.entry("Short", strategy.short, qty=position_size)
    strategy.exit("Short Exit", "Short", 
                  limit=short_take_profit, 
                  stop=short_stop_loss)

// 紧急止损 (基于布林带)
if strategy.position_size > 0 and close < bb_lower
    strategy.close("Long", comment="BB止损")
if strategy.position_size < 0 and close > bb_upper
    strategy.close("Short", comment="BB止损")

// ==================== 可视化 ====================

// 绘制移动平均线
plot(ema_fast, color=color.blue, title="快速EMA", linewidth=2)
plot(ema_slow, color=color.orange, title="慢速EMA", linewidth=2)

// 绘制布林带
p1 = plot(bb_upper, color=color.gray, title="布林带上轨")
p2 = plot(bb_lower, color=color.gray, title="布林带下轨")
fill(p1, p2, color=color.new(color.gray, 95), title="布林带填充")

// 绘制VWAP
plot(vwap, color=color.purple, title="VWAP", linewidth=1)

// 绘制交易信号
plotshape(long_institutional, title="多头信号", location=location.belowbar, 
          color=color.green, style=shape.labelup, text="LONG", size=size.small)
plotshape(short_institutional, title="空头信号", location=location.abovebar, 
          color=color.red, style=shape.labeldown, text="SHORT", size=size.small)

// 绘制大单信号
plotshape(big_order_up, title="大单买入", location=location.belowbar, 
          color=color.lime, style=shape.triangleup, size=size.tiny)
plotshape(big_order_down, title="大单卖出", location=location.abovebar, 
          color=color.fuchsia, style=shape.triangledown, size=size.tiny)

// ==================== 信息面板 ====================

// 创建信息表格
var table info_table = table.new(position.top_right, 2, 8, bgcolor=color.white, border_width=1)

if barstate.islast
    table.cell(info_table, 0, 0, "指标", text_color=color.black, bgcolor=color.gray)
    table.cell(info_table, 1, 0, "数值", text_color=color.black, bgcolor=color.gray)
    
    table.cell(info_table, 0, 1, "RSI", text_color=color.black)
    table.cell(info_table, 1, 1, str.tostring(math.round(rsi, 2)), 
               text_color=rsi > 70 ? color.red : rsi < 30 ? color.green : color.black)
    
    table.cell(info_table, 0, 2, "MACD", text_color=color.black)
    table.cell(info_table, 1, 2, str.tostring(math.round(macd_line, 4)), 
               text_color=macd_line > signal_line ? color.green : color.red)
    
    table.cell(info_table, 0, 3, "Stoch K", text_color=color.black)
    table.cell(info_table, 1, 3, str.tostring(math.round(k, 2)), 
               text_color=k > 80 ? color.red : k < 20 ? color.green : color.black)
    
    table.cell(info_table, 0, 4, "ATR", text_color=color.black)
    table.cell(info_table, 1, 4, str.tostring(math.round(atr, 4)), text_color=color.black)
    
    table.cell(info_table, 0, 5, "成交量比", text_color=color.black)
    table.cell(info_table, 1, 5, str.tostring(math.round(volume / volume_ma, 2)), 
               text_color=volume_spike ? color.green : color.black)
    
    table.cell(info_table, 0, 6, "资金流向", text_color=color.black)
    table.cell(info_table, 1, 6, str.tostring(math.round(money_flow, 2)), 
               text_color=money_flow > 50 ? color.green : color.red)
    
    table.cell(info_table, 0, 7, "5分钟趋势", text_color=color.black)
    table.cell(info_table, 1, 7, trend_up_5m ? "上涨" : "下跌", 
               text_color=trend_up_5m ? color.green : color.red)

// ==================== 策略统计 ====================

// 计算胜率
total_trades = strategy.closedtrades
winning_trades = 0
for i = 0 to total_trades - 1
    if strategy.closedtrades.profit(i) > 0
        winning_trades += 1

win_rate = total_trades > 0 ? winning_trades / total_trades * 100 : 0

// 在图表上显示胜率
if barstate.islast
    label.new(bar_index, high, 
              "胜率: " + str.tostring(math.round(win_rate, 2)) + "%\n" +
              "总交易: " + str.tostring(total_trades) + "\n" +
              "盈利交易: " + str.tostring(winning_trades),
              style=label.style_label_down, 
              color=win_rate >= 70 ? color.green : color.red,
              textcolor=color.white,
              size=size.normal)